#!/usr/bin/env bash
# Room8 Pre-Commit Hook
# Verhindert Commits mit:
# 1. Echten Umlauten in JS/TS/Python/CSS Code-Files (User-Regel: nur ae/oe/ue/ss)
# 2. Web-Dateien (*.html / *.css / *.js) im Repo-Root — Web-Code lebt AUSSCHLIESSLICH
#    in www/ (Single Source of Truth, siehe _GOLDEN-RULES.md Regel 11).
#
# UI-Texte (HTML-Content) und MD-Files sind ausgenommen.
# Bypass mit `git commit --no-verify` (nur in Notfall).

set -e
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ROOT="$(git rev-parse --show-toplevel)"
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
FAIL=0

if [ -z "$STAGED" ]; then
    exit 0
fi

# ============================================
# 1. Umlaut-Check in Code-Files (NICHT in HTML/MD)
# ============================================
CODE_FILES=$(echo "$STAGED" | grep -E '\.(js|ts|tsx|jsx|py|sh|css|json)$' || true)
# Whitelist: Files die echte UI-Strings enthalten und Umlaute brauchen
UMLAUT_OK_REGEX='(^|/)translations\.js$|(^|/)i18n\.(js|ts)$|(^|/)polish-text/index\.ts$'
if [ -n "$CODE_FILES" ]; then
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        [ ! -f "$ROOT/$file" ] && continue
        # Whitelist: i18n / translations Files duerfen Umlaute haben (sind UI-Strings)
        if echo "$file" | grep -qE "$UMLAUT_OK_REGEX"; then
            continue
        fi
        # nur HINZUGEFUEGTE Zeilen (+) pruefen, nicht entfernte (-)
        OFFENDERS=$(git diff --cached "$file" | grep -E '^\+' | grep -E '[äöüÄÖÜß]' || true)
        if [ -n "$OFFENDERS" ]; then
            echo -e "${RED}FAIL${NC} Umlaut in Code-File: $file"
            echo "$OFFENDERS" | head -3 | sed 's/^/      /'
            FAIL=1
        fi
    done <<< "$CODE_FILES"
fi

# ============================================
# 2. Keine Web-Dateien im Repo-Root
# Web-Code (HTML/CSS/JS) gehoert ausschliesslich nach www/. Frueher wurden Root
# und www/ doppelt gepflegt -> Drift. Seit dem Quality-Pass 01.06.2026 ist www/
# die Single Source of Truth. Dieser Check faengt versehentlich im Root abgelegte
# Web-Dateien (z.B. durch das alte setup_www.bat-Muster oder falsches Editieren).
# ============================================
ROOT_WEB=$(echo "$STAGED" | grep -E '^[^/]+\.(html|css|js)$' || true)
if [ -n "$ROOT_WEB" ]; then
    echo -e "${RED}FAIL${NC} Web-Datei(en) im Repo-Root gestaged — gehoeren nach www/:"
    echo "$ROOT_WEB" | sed 's/^/      - /'
    echo -e "      Verschiebe mit: ${GREEN}git mv <datei> www/<datei>${NC}"
    echo -e "      (Web-Code lebt ausschliesslich in www/ — Single Source of Truth.)"
    FAIL=1
fi

# ============================================
# Resultat
# ============================================
if [ "$FAIL" -eq 1 ]; then
    echo ""
    echo -e "${RED}Pre-Commit blockiert.${NC} Bypass mit ${YELLOW}--no-verify${NC} (nicht empfohlen)."
    exit 1
fi

echo -e "${GREEN}Pre-Commit OK${NC}"
